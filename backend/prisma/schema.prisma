generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(cuid())
  name             String              @db.VarChar(150)
  email            String              @unique @db.VarChar(255)
  passwordHash     String              @map("password_hash") @db.VarChar(255)
  role             Role                @default(STUDENT)
  isActive         Boolean             @default(true) @map("is_active")
  /// Last time this user opened/acknowledged the notification bell.
  /// Notifications with a timestamp after this are "unread". Null
  /// means every notification is still unread (never opened it yet).
  notificationsSeenAt DateTime?        @map("notifications_seen_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  answers          Answer[]            @relation("StudentAnswers")
  examTokens       ExamAccessToken[]   @relation("StudentTokens")
  examSessions     ExamSession[]       @relation("StudentSessions")
  createdExams     Exam[]              @relation("ExamCreator")
  createdQuestions QuestionBank[]      @relation("QuestionCreator")
  gradingsDone     SubjectiveGrading[] @relation("ExaminerGradings")

  @@index([role])
  @@map("users")
}

model QuestionBank {
  id                 String            @id @default(cuid())
  questionText       String            @map("question_text")
  questionType       QuestionType      @map("question_type")
  modelAnswerFileUrl String?           @map("model_answer_file_url")
  marks              Int
  difficultyLevel    DifficultyLevel   @map("difficulty_level")
  subject            String            @db.VarChar(100)
  createdById        String?           @map("created_by")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  modelAnswerText    String?           @map("model_answer_text")
  negativeMarks      Float             @default(0) @map("negative_marks")
  answers            Answer[]
  examQuestions      ExamQuestion[]
  options            Option[]
  createdBy          User?             @relation("QuestionCreator", fields: [createdById], references: [id])
  sessionQuestions   SessionQuestion[]

  @@index([subject])
  @@index([questionType])
  @@index([difficultyLevel])
  @@map("question_bank")
}

model Option {
  id            String         @id @default(cuid())
  questionId    String         @map("question_id")
  optionText    String         @map("option_text")
  isCorrect     Boolean        @default(false) @map("is_correct")
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  answerOptions AnswerOption[]
  question      QuestionBank   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("options")
}

model Exam {
  id              String   @id @default(cuid())
  title           String   @db.VarChar(200)
  subject         String   @db.VarChar(100)
  durationMinutes Int      @map("duration_minutes")
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")

  randomizationMode RandomizationMode @default(PER_STUDENT_UNIQUE) @map("randomization_mode")

  negativeMarkingEnabled Boolean @default(true) @map("negative_marking_enabled")

  /// Sum of all assigned questions' marks — set by the examiner or
  /// computed client-side from selection rules / curated pool.
  totalMarks   Int        @default(0) @map("total_marks")
  /// Minimum marks a student needs to pass this exam.
  passingMarks Int        @default(0) @map("passing_marks")
  /// DRAFT: being configured, not visible to students.
  /// PUBLISHED: visible to students within its time window.
  /// CLOSED: window has ended / manually closed, no longer joinable.
  /// ARCHIVED: retained for records, hidden everywhere by default.
  status       ExamStatus @default(PUBLISHED)

  webcamMonitoringEnabled   Boolean         @default(true) @map("webcam_monitoring_enabled")
  multiFaceDetectionEnabled Boolean         @default(true) @map("multi_face_detection_enabled")
  fullScreenModeEnabled     Boolean         @default(true) @map("full_screen_mode_enabled")
  gazeSensitivity           GazeSensitivity @default(MEDIUM) @map("gaze_sensitivity")
  maxTabSwitchWarnings      Int             @default(3) @map("max_tab_switch_warnings")

  audioMonitoringEnabled Boolean @default(false) @map("audio_monitoring_enabled")

  createdById String?  @map("created_by")
  createdBy   User?    @relation("ExamCreator", fields: [createdById], references: [id], onDelete: SetNull)

  selectionRules   ExamSelectionRule[]
  examQuestions    ExamQuestion[]
  sessions         ExamSession[]
  accessTokens     ExamAccessToken[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([subject])
  @@index([startTime, endTime])
  @@index([status])
  @@map("exams")
}

model ExamSelectionRule {
  id              String           @id @default(cuid())
  examId          String           @map("exam_id")
  subject         String?          @db.VarChar(100)
  questionType    QuestionType?    @map("question_type")
  difficultyLevel DifficultyLevel? @map("difficulty_level")
  count           Int
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  exam            Exam             @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
  @@map("exam_selection_rules")
}

model ExamQuestion {
  id            String       @id @default(cuid())
  examId        String       @map("exam_id")
  questionId    String       @map("question_id")
  marksOverride Int?         @map("marks_override")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  question      QuestionBank @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@map("exam_questions")
}

model ExamSession {
  id                String            @id @default(cuid())
  studentId         String            @map("student_id")
  examId            String            @map("exam_id")
  startTime         DateTime          @map("start_time")
  endTime           DateTime?         @map("end_time")
  status            SessionStatus     @default(IN_PROGRESS)
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  tabSwitchWarnings Int               @default(0) @map("tab_switch_warnings")
  answers           Answer[]
  exam              Exam              @relation(fields: [examId], references: [id])
  student           User              @relation("StudentSessions", fields: [studentId], references: [id])
  proctorEvents     ProctorEvent[]
  result            Result?
  sessionQuestions  SessionQuestion[]

  @@unique([studentId, examId])
  @@index([examId, status])
  @@map("exam_sessions")
}

model SessionQuestion {
  id             String       @id @default(cuid())
  examSessionId  String       @map("exam_session_id")
  questionId     String       @map("question_id")
  sequenceOrder  Int          @map("sequence_order")
  marksAllocated Int          @map("marks_allocated")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  examSession    ExamSession  @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  question       QuestionBank @relation(fields: [questionId], references: [id])

  @@unique([examSessionId, questionId])
  @@unique([examSessionId, sequenceOrder])
  @@map("session_questions")
}

model Answer {
  id               String             @id @default(cuid())
  examSessionId    String             @map("exam_session_id")
  studentId        String             @map("student_id")
  questionId       String             @map("question_id")
  timeOfSubmission DateTime           @default(now()) @map("time_of_submission")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  submittedFileUrl String?            @map("submitted_file_url")
  submittedText    String?            @map("submitted_text")
  /// Auto-graded (MCQ/MULTI_SELECT) or examiner-finalized score for
  /// this answer, after net negative marking. Null until graded.
  marksAwarded     Float?             @map("marks_awarded")
  markedForReview  Boolean            @default(false) @map("marked_for_review")   // NEW  
  selectedOptions  AnswerOption[]
  examSession      ExamSession        @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  question         QuestionBank       @relation(fields: [questionId], references: [id])
  student          User               @relation("StudentAnswers", fields: [studentId], references: [id])
  grading          SubjectiveGrading?

  @@unique([examSessionId, questionId])
  @@index([studentId])
  @@map("answers")
}

model AnswerOption {
  id        String   @id @default(cuid())
  answerId  String   @map("answer_id")
  optionId  String   @map("option_id")
  createdAt DateTime @default(now()) @map("created_at")
  answer    Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  option    Option   @relation(fields: [optionId], references: [id])

  @@unique([answerId, optionId])
  @@map("answer_options")
}

model ProctorEvent {
  id             String           @id @default(cuid())
  examSessionId  String           @map("exam_session_id")
  eventType      ProctorEventType @map("event_type")
  snapshotUrl    String?          @map("snapshot_url")
  gazeDirection  String?          @map("gaze_direction")
  gazeConfidence Float?           @map("gaze_confidence")
  faceCount      Int?             @map("face_count")
  isFlagged      Boolean          @default(false) @map("is_flagged")
  occurredAt     DateTime         @default(now()) @map("occurred_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  examSession    ExamSession      @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@index([examSessionId, eventType])
  @@index([occurredAt])
  @@map("proctor_events")
}

model SubjectiveGrading {
  id            String        @id @default(cuid())
  answerId      String        @unique @map("answer_id")
  status        GradingStatus @default(PENDING)
  aiScore       Float?        @map("ai_score")
  aiConfidence  Float?        @map("ai_confidence")
  examinerId    String?       @map("examiner_id")
  examinerScore Float?        @map("examiner_score")
  feedback      String?
  gradedAt      DateTime?     @map("graded_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  answer        Answer        @relation(fields: [answerId], references: [id], onDelete: Cascade)
  examiner      User?         @relation("ExaminerGradings", fields: [examinerId], references: [id])

  @@index([status])
  @@index([examinerId])
  @@map("subjective_gradings")
}

model Result {
  id                 String      @id @default(cuid())
  examSessionId      String      @unique @map("exam_session_id")
  aiScore            Float?      @map("ai_score")
  finalExaminerScore Float?      @map("final_examiner_score")
  feedback           String?
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  totalMarks         Float
  examSession        ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)

  @@map("results")
}

model ExamAccessToken {
  id        String    @id @default(cuid())
  token     String    @unique @db.VarChar(512)
  examId    String    @map("exam_id")
  studentId String    @map("student_id")
  issuedAt  DateTime  @default(now()) @map("issued_at")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")
  exam      Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   User      @relation("StudentTokens", fields: [studentId], references: [id])

  @@index([examId, studentId])
  @@map("exam_access_tokens")
}

enum Role {
  STUDENT
  EXAMINER
  ADMIN
}

enum QuestionType {
  MCQ
  MULTI_SELECT
  SHORT_ANSWER
  LONG_ANSWER
  IMAGE_UPLOAD
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

enum RandomizationMode {
  FIXED
  SHUFFLED_ORDER
  PER_STUDENT_UNIQUE
}

enum SessionStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  EXPIRED
}

enum GazeSensitivity {
  LOW
  MEDIUM
  HIGH
}

enum ProctorEventType {
  WEBCAM_SNAPSHOT
  GAZE_LOG
  TAB_SWITCH
  MULTI_FACE_DETECTED
}

enum GradingStatus {
  PENDING
  AI_GRADED
  IN_REVIEW
  GRADED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}
